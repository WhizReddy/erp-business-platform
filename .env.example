# ──────────────────────────────────────────────────────────────────────────────
# ERP Business Management Platform — Environment Variables
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in values before running locally or in Docker.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4004

# ── CDS Profile ──────────────────────────────────────────────────────────────
# Use 'pg' for PostgreSQL, omit for SQLite (default dev)
# CDS_ENV=pg

# ── PostgreSQL Database ───────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=erp_platform
DB_USER=erp_user
DB_PASSWORD=erp_secret

# ── JWT (Production) ─────────────────────────────────────────────────────────
# JWT_SECRET=your-super-secret-key-change-in-production
# JWT_ISSUER=https://your-auth-server.example.com
# JWT_AUDIENCE=erp-platform-api

# ── SAP XSUAA (Cloud Foundry / BTP Production) ───────────────────────────────
# VCAP_SERVICES={"xsuaa":[{"credentials":{"clientid":"...","clientsecret":"...",...}}]}
